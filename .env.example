# ─────────────────────────────────────────
# NISERS — Firebase Configuration
# ─────────────────────────────────────────
#
# 1. Go to https://console.firebase.google.com
# 2. Create a project (or use existing)
# 3. Enable: Authentication, Cloud Firestore, Storage
# 4. Go to Project Settings → General → Your apps → Web app
# 5. Copy config values below
# 6. Rename this file to .env
# 7. Restart dev server: npm run dev
#
# ⚠️ NEVER commit .env to git — it contains secret keys
# ─────────────────────────────────────────

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000:web:xxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
